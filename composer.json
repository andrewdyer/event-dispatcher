{
    "name": "andrewdyer/event-dispatcher",
    "description": "A simple event dispatcher that you can fit into the framework of your choice",
    "keywords": [],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrew Dyer",
            "homepage": "https://andrewdyer.rocks",
            "role": "developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anddye\\EventDispatcher\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Anddye\\EventDispatcher\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^7.2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "friendsofphp/php-cs-fixer": "^2.16",
        "symfony/var-dumper": "^5.0"
    },
    "scripts": {
        "cs": [
            "vendor/bin/php-cs-fixer fix"
        ]
    }
}
