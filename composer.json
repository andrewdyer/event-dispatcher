{
  "name": "andrewdyer/event-dispatcher",
  "description": "A framework-agnostic library for implementing the observer pattern through named events and registered listeners",
  "keywords": [
    "php",
    "framework-agnostic",
    "event-dispatcher",
    "events",
    "listeners",
    "observer-pattern"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrew Dyer",
      "homepage": "https://andrewdyer.rocks",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/andrewdyer/event-dispatcher",
  "support": {
    "issues": "https://github.com/andrewdyer/event-dispatcher/issues",
    "source": "https://github.com/andrewdyer/event-dispatcher"
  },
  "autoload": {
    "psr-4": {
      "AndrewDyer\\EventDispatcher\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AndrewDyer\\EventDispatcher\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
